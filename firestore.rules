rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /properties/{propertyId} {
      allow read: if resource.data.disponible == true
        || (request.auth != null && request.auth.uid == resource.data.arrendadorId);
      allow create: if request.auth != null
        && request.resource.data.arrendadorId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.arrendadorId == request.auth.uid;
    }

    match /chat_rooms/{roomId} {
      allow read, update: if request.auth != null
        && (request.auth.uid == resource.data.arrendadorId
            || request.auth.uid == resource.data.arrendatarioId);
      allow create: if request.auth != null;

      match /messages/{messageId} {
        allow read, create: if request.auth != null;
      }
    }

    match /rental_requests/{requestId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.arrendadorId
            || request.auth.uid == resource.data.arrendatarioId);
      allow create: if request.auth != null
        && request.resource.data.arrendatarioId == request.auth.uid;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.arrendadorId;
    }
  }
}
